# Database
DB_URL=jdbc:postgresql://localhost:5432/supervisesuite
DB_USERNAME=postgres
DB_PASSWORD=postgres

# App
APP_PORT=8081
# Local HTTP development must use false.
# Set true only when running over HTTPS.
COOKIE_SECURE=false

# JWT
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=replace-with-a-secure-base64-encoded-secret-of-at-least-64-bytes
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# CORS
# Comma-separated list of allowed frontend origins.
# Example for multiple: http://localhost:5173,https://app.supervisesuite.com
# Keep host consistent with frontend origin (do not mix localhost and 127.0.0.1).
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Frontend base URL used for backend setup/callback redirects.
FRONTEND_BASE_URL=http://localhost:5173

# GitHub integration
# Optional token for higher GitHub API rate limits.
GITHUB_TOKEN=
# GitHub App credentials (preferred integration mode).
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM private key; in .env use escaped new lines (\\n).
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Fallback default branch when provider metadata has no default_branch.
GITHUB_DEFAULT_BRANCH=main
# Active/idle threshold for activity summary.
GITHUB_ACTIVITY_ACTIVE_WINDOW_HOURS=48
# Preview block limits (project detail github section).
GITHUB_PREVIEW_COMMITS_LIMIT=6
GITHUB_PREVIEW_CONTRIBUTORS_LIMIT=4
# Legacy non-paginated dashboard contributors limit.
GITHUB_DASHBOARD_CONTRIBUTORS_LIMIT=5
# GitHub API page size for commit sync loop.
GITHUB_COMMITS_PAGE_SIZE=100
# Default page size for backend paginated GitHub APIs when client sends invalid size.
GITHUB_DEFAULT_PAGE_SIZE=10
# Hard upper limit for backend paginated GitHub API size.
GITHUB_MAX_PAGE_SIZE=100
# Default page size for GitHub App installation repositories listing endpoint.
GITHUB_INSTALLATION_REPOSITORIES_DEFAULT_PAGE_SIZE=100
# Hard upper limit for GitHub App installation repositories listing endpoint.
GITHUB_INSTALLATION_REPOSITORIES_MAX_PAGE_SIZE=100
