# Database
DB_URL=jdbc:postgresql://localhost:5432/supervisesuite
DB_USERNAME=postgres
DB_PASSWORD=postgres

# App
APP_PORT=8081
# Local HTTP development must use false.
# Set true only when running over HTTPS.
COOKIE_SECURE=false

# JWT
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=replace-with-a-secure-base64-encoded-secret-of-at-least-64-bytes
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# CORS
# Comma-separated list of allowed frontend origins.
# Example for multiple: http://localhost:5173,https://app.supervisesuite.com
# Keep host consistent with frontend origin (do not mix localhost and 127.0.0.1).
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Frontend base URL used for backend setup/callback redirects.
FRONTEND_BASE_URL=http://localhost:5173

# GitHub integration
# GitHub REST API base URL.
GITHUB_API_BASE_URL=https://api.github.com
# Optional token for higher GitHub API rate limits.
GITHUB_TOKEN=
# GitHub App credentials (preferred integration mode).
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_NAME=
# GitHub App installation URL (for setup/authorization redirects).
# Example: https://github.com/apps/<your-app-slug>/installations/new
GITHUB_APP_INSTALL_URL=
# PEM private key; in .env use escaped new lines (\\n).
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# Fallback default branch when provider metadata has no default_branch.
GITHUB_DEFAULT_BRANCH=main
# Active/idle threshold for activity summary.
GITHUB_ACTIVITY_ACTIVE_WINDOW_HOURS=48
# Preview block limits (project detail github section).
GITHUB_PREVIEW_COMMITS_LIMIT=6
GITHUB_PREVIEW_CONTRIBUTORS_LIMIT=4
# Legacy non-paginated dashboard contributors limit.
GITHUB_DASHBOARD_CONTRIBUTORS_LIMIT=5
# GitHub API page size for commit sync loop.
GITHUB_COMMITS_PAGE_SIZE=100
# Default page size for backend paginated GitHub APIs when client sends invalid size.
GITHUB_DEFAULT_PAGE_SIZE=10
# Hard upper limit for backend paginated GitHub API size.
GITHUB_MAX_PAGE_SIZE=100
# Max repositories that can be linked to a single project.
GITHUB_MAX_LINKED_REPOS_PER_PROJECT=5
# Max linked repositories that can stay enabled at once for a project.
GITHUB_MAX_ENABLED_REPOS_PER_PROJECT=5
# Setup callback state TTL in seconds.
GITHUB_SETUP_STATE_TTL_SECONDS=900
# Optional setup state signing secret (falls back to JWT_SECRET when empty).
GITHUB_SETUP_STATE_SECRET=
# Max GitHub commit pages fetched in one sync operation.
GITHUB_SYNC_MAX_COMMIT_PAGES=5
# Default page size for GitHub App installation repositories listing endpoint.
GITHUB_INSTALLATION_REPOSITORIES_DEFAULT_PAGE_SIZE=100
# Hard upper limit for GitHub App installation repositories listing endpoint.
GITHUB_INSTALLATION_REPOSITORIES_MAX_PAGE_SIZE=100
# Project-scoped GitHub access-request token lifetime in minutes.
GITHUB_ACCESS_REQUEST_EXPIRES_IN_MINUTES=15
# Expired access-request cleanup scheduler (runs repeatedly by fixed delay).
GITHUB_ACCESS_REQUEST_CLEANUP_ENABLED=true
GITHUB_ACCESS_REQUEST_CLEANUP_INITIAL_DELAY_MS=120000
GITHUB_ACCESS_REQUEST_CLEANUP_FIXED_DELAY_MS=900000
# Daily linked GitHub repository refresh scheduler.
# Example for 12:00 every day: 0 0 12 * * *
GITHUB_REPOSITORY_REFRESH_JOB_ENABLED=true
GITHUB_REPOSITORY_REFRESH_CRON=0 0 0 * * *
GITHUB_REPOSITORY_REFRESH_ZONE=UTC
# Max linked repositories refreshed per scheduled run.
GITHUB_REPOSITORY_REFRESH_BATCH_SIZE=50

# Jira OAuth integration (Supervisor connect flow)
# Atlassian OAuth app client id.
ATLASSIAN_CLIENT_ID=
# Atlassian OAuth app client secret (used in callback/token exchange step).
ATLASSIAN_CLIENT_SECRET=
# Minimum required read scopes only.
ATLASSIAN_SCOPE=read:jira-user read:jira-work read:project:jira read:sprint:jira-software read:board-scope:jira-software read:issue-details:jira
# OAuth audience (default Atlassian API audience).
ATLASSIAN_AUDIENCE=api.atlassian.com
# OAuth authorize endpoint.
ATLASSIAN_AUTH_TARGET_URL=https://auth.atlassian.com/authorize
# Must exactly match the redirect URI configured in Atlassian developer console.
ATLASSIAN_REDIRECT_URI=http://localhost:5173/supervisor/jira/callback
# Optional override for token exchange endpoint.
ATLASSIAN_TOKEN_TARGET_URL=https://auth.atlassian.com/oauth/token
# Secret used to encrypt Jira OAuth tokens at rest (AES-GCM via derived key).
# If empty, backend falls back to JWT_SECRET.
ATLASSIAN_TOKEN_ENCRYPTION_SECRET=
# CSRF state prefix used when generating OAuth state parameter.
ATLASSIAN_OAUTH_STATE=
# Jira OAuth state TTL in seconds (one-time nonce validity).
ATLASSIAN_OAUTH_STATE_TTL_SECONDS=900
# Jira analytics tuning
# Number of recent sprints considered for sprint velocity insights.
ATLASSIAN_ANALYTICS_RECENT_SPRINTS_LIMIT=3
# Consecutive weeks with negative net flow required to trigger backlog growth warning.
ATLASSIAN_ANALYTICS_BACKLOG_GROWING_CONSECUTIVE_WEEKS=2
# Comma-separated Jira priority names treated as high priority.
ATLASSIAN_ANALYTICS_HIGH_PRIORITY_NAMES=High,Highest
# Comma-separated Jira issue type names treated as bugs/defects.
ATLASSIAN_ANALYTICS_BUG_TYPE_NAMES=Bug
